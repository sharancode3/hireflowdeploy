# REQUIRED in production (e.g. https://api.example.com)
# OPTIONAL in local dev when using Vite proxy (/api -> localhost:4000)
VITE_API_URL=

# OPTIONAL: public frontend base URL used for auth recovery redirects (e.g. https://app.hireflow.com)
VITE_PUBLIC_APP_URL=

# REQUIRED: Supabase project URL and public anon key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OPTIONAL: comma-separated admin emails allowed to open /admin routes
VITE_ADMIN_EMAILS=Sharan18x@gmail.com
